{
  "name": "sequence-for-friends",
  "version": "1.0.0",
  "description": "Real-time multiplayer Sequence board game",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:worker",
    "dev:worker": "cd worker && npx wrangler dev",
    "dev:server": "cd server && npm run dev",
    "build": "npm run build:worker",
    "build:worker": "cd worker && npx tsc -p tsconfig.json --noEmit",
    "build:ios": "xcodebuild -project client/ios/App/App.xcodeproj -scheme App -destination 'generic/platform=iOS Simulator' build",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "cd worker && npx wrangler dev"
  },
  "keywords": [
    "sequence",
    "board-game",
    "multiplayer",
    "cloudflare-workers"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "vitest": "^1.6.0",
    "wrangler": "^4.69.0"
  }
}
